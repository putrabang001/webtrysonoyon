{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "page.html",
          "style.css",
          "script.js",
          "data/**",
          "admin/**",
          "images/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
